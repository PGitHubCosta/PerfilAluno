@model PerfilAluno.Models.Aluno

@{
    ViewData["Title"] = "Cadastro Confirmado";
}

<div class="container mt-5" style="max-width: 600px;">
    <!-- Mensagem de sucesso estilizada em verde -->
    <div class="card border-success shadow">
        <div class="card-header bg-success text-white text-center p-3">
            <h3 class="mb-0">🎉 Cadastro Realizado com Sucesso!</h3>
        </div>
        <div class="card-body p-4">
            <h4 class="text-secondary mb-3">Resumo dos Dados do Aluno:</h4>
            
            <table class="table table-striped">
                <tbody>
                    <tr>
                        <th scope="row" style="width: 40%;">Nome Completo:</th>
                        <td>@Model.Nome</td>
                    </tr>
                    <tr>
                        <th scope="row">E-mail:</th>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <th scope="row">R.A.:</th>
                        <td>@Model.RA</td>
                    </tr>
                    <tr>
                        <th scope="row">Curso:</th>
                        <td>@Model.Curso</td>
                    </tr>
                    <tr>
                        <th scope="row">Data de Nascimento:</th>
                        <td>@Model.DataNascimento.ToString("dd/MM/yyyy")</td>
                    </tr>
                </tbody>
            </table>

            <div class="mt-4 text-center">
                <!-- Botão que redireciona de volta para o formulário de cadastro -->
                <a asp-controller="Aluno" asp-action="Cadastrar" class="btn btn-outline-success btn-lg w-100">
                    🔄 Cadastrar outro aluno
                </a>
            </div>
        </div>
    </div>

    <div class="text-center mt-3">
        <a asp-action="Index" class="text-muted text-decoration-none">← Ir para a Página Inicial de Alunos</a>
    </div>
</div>
