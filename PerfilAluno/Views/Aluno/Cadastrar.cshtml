@model PerfilAluno.Models.Aluno

@{
    ViewData["Title"] = "Cadastrar Aluno";
}

<div class="container mt-4" style="max-width: 500px;">
    <h2 class="mb-4 text-primary">Cadastro de Novo Aluno</h2>

    <!-- Alerta de sucesso caso o formulário passe na validação -->
    @if (ViewBag.MensagemSucesso != null)
    {
        <div class="alert alert-success">@ViewBag.MensagemSucesso</div>
    }

    <form asp-action="Cadastrar" method="post" class="p-4 border rounded bg-light shadow-sm">
        
        <!-- Campo Nome -->
        <div class="mb-3">
            <label asp-for="Nome" class="form-label font-weight-bold"></label>
            <input asp-for="Nome" class="form-control" placeholder="Digite o nome completo" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <!-- Campo E-mail -->
        <div class="mb-3">
            <label asp-for="Email" class="form-label font-weight-bold"></label>
            <input asp-for="Email" class="form-control" placeholder="exemplo@email.com" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <!-- Campo RA -->
        <div class="mb-3">
            <label asp-for="RA" class="form-label font-weight-bold"></label>
            <input asp-for="RA" class="form-control" placeholder="Digite o R.A." />
            <span asp-validation-for="RA" class="text-danger small"></span>
        </div>

        <!-- Campo Curso -->
        <div class="mb-3">
            <label asp-for="Curso" class="form-label font-weight-bold"></label>
            <input asp-for="Curso" class="form-control" placeholder="Nome do curso acadêmico" />
            <span asp-validation-for="Curso" class="text-danger small"></span>
        </div>

        <!-- Campo Data de Nascimento -->
        <div class="mb-3">
            <label asp-for="DataNascimento" class="form-label font-weight-bold"></label>
            <input asp-for="DataNascimento" class="form-control" />
            <span asp-validation-for="DataNascimento" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-2">Salvar Cadastro</button>
    </form>

    <div class="mt-3">
        <a asp-action="Index" class="text-secondary" style="text-decoration: none;">← Voltar para a lista</a>
    </div>
</div>
