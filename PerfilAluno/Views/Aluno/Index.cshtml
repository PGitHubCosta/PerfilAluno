@{
    ViewData["Title"] = "Perfil do Aluno";
}
  
    <div style="margin-bottom: 20px;">
        <a asp-controller="Aluno" asp-action="Cadastrar" style="display: inline-block; background-color: #28a745; color: white; padding: 10px 15px; text-decoration: none; border-radius: 4px; font-weight: bold;">
            ➕ Cadastrar Novo Aluno
        </a>
    </div>

    <p><strong>Nome:</strong> @ViewBag.Nome</p>
    <p><strong>Curso:</strong> @ViewBag.Curso</p>
    <p><strong>Semestre:</strong> @ViewBag.Semestre</p>
    
    <hr>
    <a asp-controller="Aluno" asp-action="Detalhes" asp-route-id="1" style="display: inline-block; background-color: #007bff; color: white; padding: 8px 12px; text-decoration: none; border-radius: 4px;">Ver Detalhes do Aluno</a>
</div>

